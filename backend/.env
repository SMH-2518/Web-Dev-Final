# Environment Variables for ProtecSure Backend
# Fill in your actual values below

# Database Configuration (MySQL)
DB_URL=jdbc:mysql://localhost:3306/protecsure
DB_USER=root
DB_PASSWORD=password

# Email Configuration (Gmail SMTP)
